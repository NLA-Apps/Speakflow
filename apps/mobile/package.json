    "expo-constants": "~56.0.21",
    "expo-crypto": "~56.0.1",
    "expo-dev-client": "~56.0.15",
    "expo-linking": "~56.0.15",
    "expo-network": "~56.0.2",
    "expo-router": "~56.2.15",
    "expo-speech": "~56.0.3",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
